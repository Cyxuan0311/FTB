{
    "name": "sysinfo",
    "version": "1.1.0",
    "description": "Display CPU usage, network status, and battery level in the status bar",
    "author": "FTB",
    "entry": "main.ts",
    "type": "statusbar",
    "permissions": {
        "fs_read": true,
        "fs_write": true,
        "subprocess": true,
        "python_exec": true,
        "max_exec_ms": 3000
    }
}
